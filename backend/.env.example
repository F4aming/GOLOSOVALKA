APP_NAME=Voting Platform API
APP_ENV=dev
APP_HOST=127.0.0.1
APP_PORT=8000

DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/voting_platform

JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

